# Postgres connection string (plain — TLS terminates at the ingress).
DATABASE_URL=postgres://user:password@localhost:5432/pick_me_a_dinner

# Single shared password gating every route (ADR-0002).
APP_PASSWORD=change-me

# Secret used to seal the iron-session cookie — at least 32 characters.
APP_SECRET=replace-with-a-long-random-string-of-32-plus-chars

# IANA timezone for the household's local calendar day.
APP_TZ=America/Los_Angeles

# Optional — when unset, the Catalog hides the Google Places search box.
GOOGLE_PLACES_API_KEY=

# Optional — Anthropic API key for AI search on Tonight. When unset, AI search
# is simply absent; the deterministic ranking is unaffected.
ANTHROPIC_API_KEY=

# Optional — the Claude model AI search calls. Defaults to a current Sonnet.
AI_MODEL=
