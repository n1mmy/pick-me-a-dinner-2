# Committed, secret-free environment defaults — safe to commit (no API
# keys). Real secrets live only in the gitignored `.env`. Materialise a
# fresh worktree's `.env` with:  cp .env.ralph .env

# Dev Postgres — the `pmad-pg` Docker container on localhost:5434.
DATABASE_URL=postgres://postgres:postgres@localhost:5434/pmad

# Dev-only shared login password (ADR-0002) — not a real secret.
APP_PASSWORD=ralph

# Dev-only iron-session sealing key, 32+ chars — not a real secret.
APP_SECRET=ralph-loop-dev-secret-not-for-production-use

# Household local-day timezone.
APP_TZ=America/Los_Angeles

# API keys deliberately omitted — AI search and Places autofill stay off
# under the loop. Put real keys in a `.env` if you need them.
GOOGLE_PLACES_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=
